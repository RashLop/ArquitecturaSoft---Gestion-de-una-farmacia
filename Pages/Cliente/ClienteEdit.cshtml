@page "{id:int}"
@model ProyectoArqSoft.Pages.ClienteEditModel
@{
    ViewData["Title"] = "Editar Cliente";
}

<h2>Editar Cliente</h2>

<form method="post">
    <input type="hidden" asp-for="IdCliente" />

    <div class="form-group mb-2">
        <label>Tipo de Cliente</label>
        <select asp-for="Tipo_Cliente" class="form-control">
            <option value="">Seleccione...</option>
            <option value="Regular">Regular</option>
            <option value="Frecuente">Frecuente</option>
            <option value="VIP">VIP</option>
        </select>
    </div>

    <div class="form-group mb-2">
        <label>Nombre Completo</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Carnet de Identidad</label>
        <input asp-for="Carnet" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Edad</label>
        <input asp-for="Edad" type="number" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Teléfono</label>
        <input asp-for="Telefono" class="form-control" />
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    <a asp-page="Cliente" class="btn btn-secondary">Volver</a>
</form>