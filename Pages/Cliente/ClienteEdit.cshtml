@page
@model ProyectoArqSoft.Pages.ClienteEditModel
@{
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0">Actualizar Cliente</h2>
                    <p class="text-muted mt-2 mb-0">Modifica los datos del cliente seleccionado</p>
                </div>

                <div class="med-card-body">
                    <form method="post" asp-page-handler="ActualizarCliente">

                        <input type="hidden" asp-for="IdCliente" />

                        <!-- TIPO DE CLIENTE -->
                        <div class="form-floating mb-3">
                            <select asp-for="TipoCliente" class="form-select med-input" required>
                                <option value="" disabled>Seleccione un tipo de cliente</option>
                                <option value="Regular">Regular</option>
                                <option value="Frecuente">Crónico</option>
                                <option value="VIP">Seguro / Institucional</option>
                            </select>
                            <label asp-for="TipoCliente"></label>
                        </div>

                        <!-- NOMBRE Y APELLIDOS -->
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Nombre" class="form-control med-input" placeholder="Nombre" required />
                                    <label asp-for="Nombre"></label>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <input asp-for="ApellidoPaterno" class="form-control med-input" placeholder="Apellido Paterno" required />
                                    <label asp-for="ApellidoPaterno"></label>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <input asp-for="ApellidoMaterno" class="form-control med-input" placeholder="Apellido Materno" required />
                                    <label asp-for="ApellidoMaterno"></label>
                                </div>
                            </div>
                        </div>

                        <!-- CI + EXTENSION -->
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Ci"
                                           class="form-control med-input"
                                           placeholder="Ej: 1234567 o 1234567-1A"
                                           required />
                                    <label asp-for="Ci"></label>
                                </div>
                                <div class="form-text">
                                    Ej: 1234567 o 1234567-1A
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <select asp-for="CiExtencion" class="form-select med-input" required>
                                        <option value="" disabled>Seleccione extensión</option>
                                        <option value="LP">LP</option>
                                        <option value="CB">CB</option>
                                        <option value="SC">SC</option>
                                        <option value="OR">OR</option>
                                        <option value="PT">PT</option>
                                        <option value="CH">CH</option>
                                        <option value="TJ">TJ</option>
                                        <option value="BE">BE</option>
                                        <option value="PD">PD</option>
                                    </select>
                                    <label asp-for="CiExtencion"></label>
                                </div>
                            </div>
                        </div>

                        <!-- FECHA NACIMIENTO -->
                        <div class="form-floating mb-3">
                            <input asp-for="FechaDeNacimiento"
                                   type="date"
                                   class="form-control med-input"
                                   required />
                            <label asp-for="FechaDeNacimiento"></label>
                        </div>

                        <!-- TELEFONO -->
                        <div class="form-floating mb-3">
                            <input asp-for="Telefono"
                                   class="form-control med-input"
                                   placeholder="Teléfono" />
                            <label asp-for="Telefono"></label>
                        </div>

                        <!-- MENSAJES -->
                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert" role="alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <!-- BOTONES -->
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Cliente" class="btn med-btn-secondary">Volver</a>
                            <button type="submit" class="btn med-btn-primary">Actualizar</button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>