@page "{id:int}"
@model ProyectoArqSoft.Pages.Cliente.ClienteEditModel
@{
    ViewData["Title"] = "Editar Cliente";
}

<h1 class="mb-4">Editar Cliente</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Modifique los datos del cliente</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label asp-for="Tipo_Cliente" class="control-label">Tipo de Cliente</label>
                        <select asp-for="Tipo_Cliente" class="form-control" required>
                            <option value="">Seleccione...</option>
                            <option value="Regular">Regular</option>
                            <option value="VIP">VIP</option>
                            <option value="Corporativo">Corporativo</option>
                        </select>
                        <span asp-validation-for="Tipo_Cliente" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Nombre" class="control-label">Nombre Completo</label>
                        <input asp-for="Nombre" class="form-control" required />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Carnet" class="control-label">Carnet de Identidad</label>
                        <input asp-for="Carnet" class="form-control" required />
                        <span asp-validation-for="Carnet" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Edad" class="control-label">Edad</label>
                        <input asp-for="Edad" type="number" min="1" max="120" class="form-control" required />
                        <span asp-validation-for="Edad" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Telefono" class="control-label">Teléfono</label>
                        <input asp-for="Telefono" class="form-control" required />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save"></i> Guardar Cambios
                        </button>
                        <a asp-page="./Cliente" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver al Listado
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}