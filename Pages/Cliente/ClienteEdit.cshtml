@page
@model ProyectoArqSoft.Pages.ClienteEditModel
@{
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning">
                    <h2 class="h4 mb-0">Actualizar Cliente</h2>
                </div>

                <div class="card-body p-4">
                    <form method="post" asp-page-handler="ActualizarCliente">
                        <input type="hidden" asp-for="IdCliente" />

                        <div class="mb-3">
                            <label class="form-label">Tipo de Cliente</label>
                            <select asp-for="TipoCliente" class="form-control" required>
                                <option value="">Seleccione...</option>
                                <option value="Regular">Regular</option>
                                <option value="Frecuente">Frecuente</option>
                                <option value="VIP">VIP</option>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Nombre</label>
                                <input asp-for="Nombre" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Apellido Materno</label>
                                <input asp-for="ApellidoMaterno" class="form-control" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Apellido Paterno</label>
                                <input asp-for="ApellidoPaterno" class="form-control" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Extension CI</label>
                                <select asp-for="CiExtencion" class="form-control" required>
                                    <option value="">Seleccione...</option>
                                    <option value="LP">LP</option>
                                    <option value="CB">CB</option>
                                    <option value="SC">SC</option>
                                    <option value="OR">OR</option>
                                    <option value="PT">PT</option>
                                    <option value="CH">CH</option>
                                    <option value="TJ">TJ</option>
                                    <option value="BE">BE</option>
                                    <option value="PD">PD</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Carnet</label>
                                <input asp-for="Ci" class="form-control" placeholder="Ej: 1234567 o 1234567-1A" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Nacimiento</label>
                                <input asp-for="FechaDeNacimiento" type="date" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Telefono</label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger">@Model.Estado.MensajeError</div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Guardar</button>
                            <a asp-page="Cliente" class="btn btn-secondary">Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
