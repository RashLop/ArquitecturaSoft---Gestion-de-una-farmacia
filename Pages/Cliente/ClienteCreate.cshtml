@page
@model ProyectoArqSoft.Pages.ClienteCreateModel
@{
    ViewData["Title"] = "Registrar Cliente";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header text-white" style="background-color: var(--azul-vital);">
                    <h5 class="mb-0">
                        <i class="bi bi-person-plus me-2"></i>Registrar Cliente
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">NIT</label>
                                <input asp-for="Nit" class="form-control" placeholder="Ej: 123456789" />
                                <span asp-validation-for="Nit" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Correo Electrónico</label>
                                <input asp-for="CorreoElectronico" type="email" class="form-control" placeholder="ejemplo@empresa.com" />
                                <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Razón Social</label>
                                <input asp-for="RazonSocial" class="form-control" placeholder="Ej: Farmacias de Similares S.A. de C.V." />
                                <span asp-validation-for="RazonSocial" class="text-danger"></span>
                                <small class="text-muted">
                                    Mínimo 10 caracteres, máximo 36. Solo letras, espacios, puntos y guiones.<br />
                                    Los espacios múltiples se normalizarán automáticamente.
                                </small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Fecha de Registro</label>
                                <input asp-for="FechaRegistro" type="date" class="form-control" />
                                <span asp-validation-for="FechaRegistro" class="text-danger"></span>
                            </div>
                        </div>

                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                        }

                        <div class="d-flex gap-2 justify-content-end mt-4">
                            <a asp-page="/Cliente/Cliente" class="btn btn-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-save"></i> Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}