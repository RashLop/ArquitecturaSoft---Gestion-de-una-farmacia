@page
@model ProyectoArqSoft.Pages.ClienteCreateModel
@{
    ViewData["Title"] = "Registrar Cliente";
}

<h2>Registrar Cliente</h2>

<form method="post">
    <div class="form-group mb-2">
        <label>Tipo de Cliente</label>
        <select asp-for="Tipo_Cliente" class="form-control">
            <option value="">Seleccione...</option>
            <option value="Regular">Regular</option>
            <option value="Frecuente">Frecuente</option>
            <option value="VIP">VIP</option>
        </select>
    </div>

    <div class="form-group mb-2">
        <label>Nombre Completo</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Carnet de Identidad</label>
        <input asp-for="Carnet" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Edad</label>
        <input asp-for="Edad" type="number" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>TelÈfono</label>
        <input asp-for="Telefono" class="form-control" />
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-page="Cliente" class="btn btn-secondary">Volver</a>
</form>