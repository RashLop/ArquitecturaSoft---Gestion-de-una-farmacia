@page
@model ProyectoArqSoft.Pages.ClienteCreateModel
@{
}

<h1>Nuevo cliente</h1>
<div class="card-body p-4">
<form method="post">
    <div class="form-group">
        <label>Nombre:</label>
        <input asp-for="@Model.Nombre" class="form-control"required/>
    </div>
    <div class="form-group">
        <label>Tipo Cliente:</label>
        <input asp-for="@Model.Tipo_Cliente" class="form-control"required/>
    </div>
    <div class="form-group">
        <label>Carnet:</label>
        <input asp-for="@Model.Carnet" class="form-control"required/>
    </div>

    <div class="form-group">
        <label>Edad:</label>
        <input asp-for="@Model.Edad" class="form-control"required/>
    </div>

    <div class="form-group">
        <label>Telefono:</label>
        <input asp-for="@Model.Telefono" class="form-control"required/>
    </div>
    <button type="submit" class="btn btn-primary mt-2">Guardar</button>
    <a asp-page="Cliente" class="btn btn-secondary mt-2">Volver</a>

</form>
</div>
