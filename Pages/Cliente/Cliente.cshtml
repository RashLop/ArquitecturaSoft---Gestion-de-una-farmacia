@page
@model ProyectoArqSoft.Pages.ClienteModel
@{
}


<h1 class="mb-3">Registro De Clientes </h1>


<form method="get" class="row mb-3">
    <div class="col-md-3">
        <select asp-for="TipoBusqueda" class="form-control">
            <option value="">Seleccione criterio</option>
            <option value="nombre">Nombre</option>
            <option value="ci">Carnet</option>
            <option value="telefono">Telefono</option>
        </select>
    </div>

    <div class="col-md-4">
        <input asp-for="TextoBusqueda" class="form-control" placeholder="Ingrese dato a buscar" />
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-success">Buscar</button>
    </div>

    <div class="col-md-2">
        <a asp-page="Cliente" class="btn btn-secondary">Limpiar</a>
    </div>
</form>



@if (Model.Mensaje != "")
{
    <div class="alert alert-warning">
        @Model.Mensaje
    </div>
}



<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Tipo de Cliente</th>
            <th>Carnet </th>
            <th>Edad</th>
            <th>Telefono</th>
             <th>acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach(System.Data.DataRow row in Model.Clientes_DataTable.Rows)
        {
            <tr>
                <td>@row["nombre" ]</td>
                <td>@row["tipo_cliente" ]</td>
                <td>@row["ci" ]</td>
                <td>@row["edad" ]</td>
                <td>@row["telefono" ]</td>
                <td>
                    <a asp-route-id="@row["idCliente"]" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-route-id="@row["idCliente"]" class="btn btn-warning btn-sm">Eliminar</a>
                </td>
            </tr>
        }

    </tbody>
</table>



