@page
@model ProyectoArqSoft.Pages.ClienteModel  // ← SIN .Cliente, directo
@{
    var modalId = "confirmarEliminarClienteModal";
}

<div class="container mt-5">

    <!-- TITULO Y BOTON NUEVO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: var(--azul-vital);">👥 Clientes</h2>
        <a asp-page="/Cliente/ClienteCreate" class="btn-main">+ Nuevo Cliente</a>
    </div>

    <!-- BUSCADOR -->
    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por NIT, razón social o correo..."
                       value="@Model.Estado.FiltroActual" />
                <button type="submit" class="btn btn-success">Buscar</button>
                <a asp-page="/Cliente/Cliente" class="btn btn-secondary">Limpiar</a>
            </div>
        </div>
    </form>

    <!-- MENSAJES -->
    @if (!string.IsNullOrEmpty(Model.Estado.Mensaje))
    {
        <div class="alert alert-success">@Model.Estado.Mensaje</div>
    }

    @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
    {
        <div class="alert alert-danger">@Model.Estado.MensajeError</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- TABLA -->
    <div class="card-module">
        <table class="table table-hover">
            <thead class="table-success">
                <tr>
                    <th>NIT</th>
                    <th>Razón Social</th>
                    <th>Correo Electrónico</th>
                    <th>Fecha Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ClienteDataTable != null && Model.ClienteDataTable.Rows.Count > 0)
                {
                    @foreach (System.Data.DataRow row in Model.ClienteDataTable.Rows)
                    {
                        <tr>
                            <td>@row["nit"]</td>
                            <td>@row["razon_social"]</td>
                            <td>@row["correo_electronico"]</td>
                            <td>@Convert.ToDateTime(row["fecha_registro"]).ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-page="/Cliente/ClienteEdit" asp-route-id="@row["idCliente"]"
                                   class="btn btn-warning btn-sm">Editar</a>
                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#@modalId"
                                        data-id="@row["idCliente"]"
                                        data-nombre="@row["razon_social"]">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No hay clientes registrados
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- MODAL DE CONFIRMACIÓN -->
    <div class="modal fade" id="@modalId" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro de eliminar al cliente <strong id="clienteNombre"></strong>?</p>
                    <p class="text-danger">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form method="post" asp-page-handler="EliminarClienteLogicamente">
                        <input type="hidden" name="id" id="clienteId" />
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const modal = document.getElementById('@modalId');
        if (modal) {
            modal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                document.getElementById('clienteNombre').textContent = button.getAttribute('data-nombre');
                document.getElementById('clienteId').value = button.getAttribute('data-id');
            });
        }
    </script>
}