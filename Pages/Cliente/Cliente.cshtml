@page
@model ProyectoArqSoft.Pages.ClienteModel
@{
}


<h1 class="mb-3">Registro De Clientes </h1>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Tipo de Cliente</th>
            <th>Carnet </th>
            <th>Edad</th>
            <th>Telefono</th>
             <th>acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach(System.Data.DataRow row in Model.Clientes_DataTable.Rows)
        {
            <tr>
                <td>@row["nombre" ]</td>
                <td>@row["tipo_cliente" ]</td>
                <td>@row["ci" ]</td>
                <td>@row["edad" ]</td>
                <td>@row["telefono" ]</td>
                <td>
                    <a asp-route-id="@row["idCliente"]" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-route-id="@row["idCliente"]" class="btn btn-warning btn-sm">Eliminar</a>
                </td>
            </tr>
        }

    </tbody>
</table>



