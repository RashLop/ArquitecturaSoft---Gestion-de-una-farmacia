@page
@model ProyectoArqSoft.Pages.ClienteModel
@{
    ViewData["Title"] = "Clientes";
}

<h1 class="mb-4">Gesti¾n de Clientes</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @Model.Mensaje
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Formulario de B·squeda -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Buscar Clientes</h5>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <select name="TipoBusqueda" class="form-control" asp-for="TipoBusqueda">
                            <option value="">Seleccione criterio</option>
                            <option value="nombre">Nombre</option>
                            <option value="ci">Carnet</option>
                            <option value="telefono">Telķfono</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="text" name="TextoBusqueda" class="form-control"
                               placeholder="Ingrese dato a buscar" asp-for="TextoBusqueda" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary">Buscar</button>
                        <a asp-page="Cliente" class="btn btn-secondary">Limpiar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <a asp-page="ClienteCreate" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Cliente
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Tipo de Cliente</th>
                <th>Carnet</th>
                <th>Edad</th>
                <th>Telķfono</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Clientes_DataTable.Rows.Count > 0)
            {
                @foreach (System.Data.DataRow row in Model.Clientes_DataTable.Rows)
                {
                    <tr>
                        <td>@row["idCliente"]</td>
                        <td>@row["nombre"]</td>
                        <td>@row["tipo_cliente"]</td>
                        <td>@row["ci"]</td>
                        <td>@row["edad"]</td>
                        <td>@row["telefono"]</td>
                        <td>
                            <a asp-page="ClienteEdit" asp-route-id="@row["idCliente"]" class="btn btn-sm btn-warning">
                                Editar
                            </a>
                            <button type="button" class="btn btn-sm btn-danger"
                                    onclick="confirmDelete(@row["idCliente"], '@row["nombre"]')">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">No hay clientes para mostrar</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal de Confirmaci¾n de Eliminaci¾n -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirmar Eliminaci¾n</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>┐Estß seguro que desea eliminar al cliente <strong id="clienteNombre"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle"></i> Esta acci¾n no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Delete" id="deleteForm">
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, nombre) {
            document.getElementById('clienteNombre').textContent = nombre;
            document.getElementById('deleteId').value = id;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
}