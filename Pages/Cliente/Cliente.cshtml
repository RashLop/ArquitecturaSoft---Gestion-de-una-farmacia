<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-success">👥 Clientes Registrados</h3>

        <a asp-page="ClienteCreate" class="btn-main">
            + Nuevo Cliente
        </a>
    </div>

    <form method="get" class="mb-4">
        <div class="card-module p-3">
            <div class="input-group">
                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por nombre, apellidos, tipo, CI o telefono..."
                       value="@Model.Estado.FiltroActual" />

                <button type="submit" class="btn btn-success btn-fixed">
                    Buscar
                </button>

                <a asp-page="Cliente" class="btn btn-secondary btn-fixed">
                    Limpiar
                </a>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.Estado.Mensaje))
    {
        <div class="alert alert-success shadow-sm">@Model.Estado.Mensaje</div>
    }

    @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
    {
        <div class="alert alert-danger shadow-sm">@Model.Estado.MensajeError</div>
    }

    <div class="card-module">
        <table class="table table-hover align-middle">
            <thead class="table-success" >
                <tr>
                    <th>Nombre</th>
                    <th>Apellido Paterno</th>
                    <th>Apellido Materno</th>
                    <th>Tipo de cliente</th>
                    <th>Carnet</th>
                    <th>Fecha de nacimiento</th>
                    <th>Telefono</th>
                    <th style="width:170px">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (System.Data.DataRow row in Model.ClienteDataTable.Rows)
                {
                    <tr>
                        <td class="fw-semibold">@row["nombre"]</td>
                        <td>@row["apellido_paterno"]</td>
                        <td>@row["apellido_materno"]</td>
                        
                        <td>
                            <span class="badge bg-info text-dark">
                                @row["tipo_cliente"]
                            </span>
                        </td>
                        <td>@row["ci"] @row["ci_extencion"]</td>
                        <td>@Convert.ToDateTime(row["fecha_de_nacimiento"]).ToString("dd/MM/yyyy")</td>
                        <td>@row["telefono"]</td>
                        <td>
                            <form method="post"
                                  asp-page="ClienteEdit"
                                  asp-page-handler="CargarClienteParaEdicion"
                                  style="display:inline;">
                                <input type="hidden" name="id" value="@row["idCliente"]" />
                                <button type="submit" class="btn btn-warning btn-sm" style="background-color: #838B8E;" >
                                    Editar
                                </button>
                            </form>

                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#@modalId"
                                    data-id="@row["idCliente"]"
                                    data-nombre="@row["nombre"] @row["apellido_paterno"]">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="@modalId" tabindex="-1" aria-labelledby="@(modalId)Label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header text-white" style="background-color: #0b5d3b;">
                    <h5 class="modal-title" id="@(modalId)Label">Confirmar eliminacion</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">Esta seguro de que desea eliminar este cliente?</p>
                    <p class="fw-semibold mb-0" id="clienteEliminarNombre"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form method="post" asp-page-handler="EliminarClienteLogicamente">
                        <input type="hidden" name="id" id="clienteEliminarId" />
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        (() => {
            const modal = document.getElementById('@modalId');
            if (!modal) return;

            modal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const nombre = button.getAttribute('data-nombre');

                modal.querySelector('#clienteEliminarId').value = id;
                modal.querySelector('#clienteEliminarNombre').textContent = nombre;
            });
        })();
    </script>
}
