@page
@model ProyectoArqSoft.Pages.ClienteModel
@{
    ViewData["Title"] = "Clientes";
}

<h1 class="mb-4">Gestión de Clientes</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @Model.Mensaje
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Formulario de Búsqueda -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Buscar Clientes</h5>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-4">
                        <select name="TipoBusqueda" class="form-control" asp-for="TipoBusqueda">
                            <option value="">Seleccione criterio</option>
                            <option value="nombre">Nombre</option>
                            <option value="ci">Carnet</option>
                            <option value="telefono">Teléfono</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="text" name="TextoBusqueda" class="form-control"
                               placeholder="Ingrese dato a buscar" asp-for="TextoBusqueda" />
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-success me-2">Buscar</button>
                        <a asp-page="Cliente" class="btn btn-secondary">Limpiar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <a asp-page="ClienteCreate" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Cliente
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre Completo</th>
                <th>Tipo</th>
                <th>Carnet</th>
                <th>Edad</th>
                <th>Teléfono</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Clientes_DataTable.Rows.Count > 0)
            {
                @foreach (System.Data.DataRow row in Model.Clientes_DataTable.Rows)
                {
                    <tr>
                        <td>@row["nombre_completo"]</td>
                        <td>@row["tipo_cliente"]</td>
                        <td>@row["ci_completo"]</td>
                        <td>@row["edad"] ańos</td>
                        <td>@row["telefono"]</td>
                        <td>
                            <div class="d-flex gap-2" role="group">
                                <a asp-page="ClienteEdit" asp-route-id="@row["idCliente"]"
                                   class="btn btn-sm btn-success" style="min-width: 70px;">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <button type="button" class="btn btn-sm btn-success" style="min-width: 70px;"
                                        onclick="confirmDelete(@row["idCliente"], '@row["nombre_completo"]')">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No hay clientes para mostrar</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal de Confirmación de Eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirmar Eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>żEstá seguro que desea eliminar al cliente <strong id="clienteNombre"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle"></i> Esta acción no se puede deshacer.</p>

                <div class="alert alert-warning mt-3" id="secondConfirm" style="display: none;">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="confirmDeleteCheck">
                        <label class="form-check-label" for="confirmDeleteCheck">
                            Confirmo que deseo eliminar permanentemente este cliente
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" asp-page-handler="Delete" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-success" id="confirmDeleteBtn" disabled>
                        <i class="bi bi-trash"></i> Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, nombre) {
            document.getElementById('clienteNombre').textContent = nombre;
            document.getElementById('deleteId').value = id;

            document.getElementById('secondConfirm').style.display = 'none';
            document.getElementById('confirmDeleteCheck').checked = false;
            document.getElementById('confirmDeleteBtn').disabled = true;

            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();

            setTimeout(function() {
                document.getElementById('secondConfirm').style.display = 'block';
            }, 1000);

            document.getElementById('confirmDeleteCheck').addEventListener('change', function(e) {
                document.getElementById('confirmDeleteBtn').disabled = !e.target.checked;
            });
        }
    </script>
}