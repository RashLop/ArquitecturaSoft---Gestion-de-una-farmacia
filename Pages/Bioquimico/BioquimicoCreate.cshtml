@page
@model ProyectoArqSoft.Pages.Bioquimico.BioquimicoCreateModel
@{
    ViewData["Title"] = "Nuevo Bioquímico";
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0 text-success">Nuevo Bioquímico</h2>
                    <p class="text-muted mt-2 mb-0">
                        Registra al bioquímico con los mismos datos base del registro de usuario.
                    </p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Nombres" class="form-control med-input" placeholder="Nombres" />
                            <label asp-for="Registro.Nombres">Nombres</label>
                            <span asp-validation-for="Registro.Nombres" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.ApellidoPaterno" class="form-control med-input" placeholder="Primer apellido" />
                                    <label asp-for="Registro.ApellidoPaterno">Primer apellido</label>
                                    <span asp-validation-for="Registro.ApellidoPaterno" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.ApellidoMaterno" class="form-control med-input" placeholder="Segundo apellido" />
                                    <label asp-for="Registro.ApellidoMaterno">Segundo apellido (opcional)</label>
                                    <span asp-validation-for="Registro.ApellidoMaterno" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Registro.Ci" class="form-control med-input" placeholder="Carnet de identidad" />
                                    <label asp-for="Registro.Ci">Carnet de identidad</label>
                                    <span asp-validation-for="Registro.Ci" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CiComplemento" class="form-control med-input" placeholder="Complemento" maxlength="2" />
                                    <label asp-for="CiComplemento">Complemento</label>
                                </div>
                            </div>

                            <div class="col-md-3 mb-3">
                                <div class="form-floating">
                                    <select asp-for="Registro.CiExtencion" class="form-select med-input">
                                        <option value="">Seleccione</option>
                                        <option value="BE">Beni</option>
                                        <option value="CB">Cochabamba</option>
                                        <option value="CH">Chuquisaca</option>
                                        <option value="LP">La Paz</option>
                                        <option value="OR">Oruro</option>
                                        <option value="PD">Pando</option>
                                        <option value="PT">Potosí</option>
                                        <option value="SC">Santa Cruz</option>
                                        <option value="TJ">Tarija</option>
                                    </select>
                                    <label asp-for="Registro.CiExtencion">Expedido en</label>
                                    <span asp-validation-for="Registro.CiExtencion" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Telefono" class="form-control med-input" placeholder="Teléfono" />
                            <label asp-for="Registro.Telefono">Teléfono</label>
                            <span asp-validation-for="Registro.Telefono" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Registro.Email" type="email" class="form-control med-input" placeholder="Correo electrónico" />
                            <label asp-for="Registro.Email">Correo electrónico</label>
                            <span asp-validation-for="Registro.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted">
                                El nombre de usuario y la contraseña temporal serán generados automáticamente por el sistema.
                            </small>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
                        {
                            <div class="alert alert-danger shadow-sm" role="alert">
                                @Model.MensajeError
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.MensajeOk))
                        {
                            <div class="alert alert-success shadow-sm" role="alert">
                                @Model.MensajeOk
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                            <a asp-page="Bioquimico" class="btn med-btn-secondary">Cancelar</a>
                            <button type="submit" class="btn med-btn-primary px-4">Guardar Registro</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}