@page
@model ProyectoArqSoft.Pages.Bioquimico.BioquimicoCreateModel
@{
    ViewData["Title"] = "Nuevo Bioquímico";
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0 text-success">Nuevo Bioquímico</h2>
                    <p class="text-muted mt-2 mb-0">Registra al profesional usando la cuenta de usuario del sistema.</p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post" asp-page-handler="CrearBioquimico">
                        <div class="form-floating mb-3">
                            <input asp-for="Nombres" class="form-control med-input" placeholder="Nombres" required />
                            <label asp-for="Nombres">Nombres</label>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="ApellidoPaterno" class="form-control med-input" placeholder="Primer Apellido" required />
                                    <label asp-for="ApellidoPaterno">Primer Apellido</label>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="ApellidoMaterno" class="form-control med-input" placeholder="Segundo Apellido" />
                                    <label asp-for="ApellidoMaterno">Segundo Apellido</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Ci" class="form-control med-input" placeholder="Carnet de Identidad" required />
                                    <label asp-for="Ci">Carnet de Identidad</label>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <select asp-for="CiExtencion" class="form-select med-input" required>
                                        <option value="" selected disabled>Expedido</option>
                                        <option value="LP">LP</option>
                                        <option value="CB">CB</option>
                                        <option value="SC">SC</option>
                                        <option value="OR">OR</option>
                                        <option value="PT">PT</option>
                                        <option value="CH">CH</option>
                                        <option value="TJ">TJ</option>
                                        <option value="BE">BE</option>
                                        <option value="PD">PD</option>
                                    </select>
                                    <label asp-for="CiExtencion">Expedido</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Telefono" class="form-control med-input" placeholder="Teléfono" required />
                            <label asp-for="Telefono">Teléfono</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" type="email" class="form-control med-input" placeholder="Correo Electrónico" required />
                            <label asp-for="Email">Correo Electrónico</label>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="UserName" class="form-control med-input" placeholder="Nombre de Usuario" required />
                                    <label asp-for="UserName">Nombre de Usuario</label>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Password" type="password" class="form-control med-input" placeholder="Contraseña Temporal" required />
                                    <label asp-for="Password">Contraseña Temporal</label>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert shadow-sm" role="alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                            <a asp-page="Bioquimico" class="btn med-btn-secondary">
                                Cancelar
                            </a>
                            <button type="submit" class="btn med-btn-primary px-4">
                                Guardar Registro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
