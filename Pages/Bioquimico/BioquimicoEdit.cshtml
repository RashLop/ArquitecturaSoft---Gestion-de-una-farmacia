@page
@model ProyectoArqSoft.Pages.Bioquimico.BioquimicoEditModel
@{
    ViewData["Title"] = "Actualizar Bioquímico";
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0 text-success">Actualizar Bioquímico</h2>
                    <p class="text-muted mt-2 mb-0">Edita los datos personales y de acceso del profesional.</p>
                </div>

                <div class="med-card-body p-4">
                    <form method="post" asp-page-handler="ActualizarBioquimico">
                        <input type="hidden" asp-for="Input.IdUsuario" />
                        <input type="hidden" asp-for="Input.Role" />
                        <input type="hidden" asp-for="Input.MustChangePassword" />

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Nombres" class="form-control med-input" placeholder="Nombres" required />
                            <label asp-for="Input.Nombres">Nombres</label>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ApellidoPaterno" class="form-control med-input" placeholder="Primer Apellido" required />
                                    <label asp-for="Input.ApellidoPaterno">Primer Apellido</label>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ApellidoMaterno" class="form-control med-input" placeholder="Segundo Apellido" />
                                    <label asp-for="Input.ApellidoMaterno">Segundo Apellido</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Ci" class="form-control med-input" placeholder="Carnet de Identidad" required />
                                    <label asp-for="Input.Ci">Carnet de Identidad</label>
                                </div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <div class="form-floating">
                                    <select asp-for="Input.CiExtencion" class="form-select med-input" required>
                                        <option value="LP">LP</option>
                                        <option value="CB">CB</option>
                                        <option value="SC">SC</option>
                                        <option value="OR">OR</option>
                                        <option value="PT">PT</option>
                                        <option value="CH">CH</option>
                                        <option value="TJ">TJ</option>
                                        <option value="BE">BE</option>
                                        <option value="PD">PD</option>
                                    </select>
                                    <label asp-for="Input.CiExtencion">Expedido</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Telefono" class="form-control med-input" placeholder="Teléfono" required />
                            <label asp-for="Input.Telefono">Teléfono</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" type="email" class="form-control med-input" placeholder="Correo Electrónico" required />
                            <label asp-for="Input.Email">Correo Electrónico</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.UserName" class="form-control med-input" placeholder="Nombre de Usuario" required />
                            <label asp-for="Input.UserName">Nombre de Usuario</label>
                        </div>

                        <div class="form-floating mb-3">
                            <select asp-for="Input.Activo" class="form-select med-input">
                                <option value="1">Activo</option>
                                <option value="0">De baja</option>
                            </select>
                            <label asp-for="Input.Activo">Estado</label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert shadow-sm" role="alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4 border-top pt-3">
                            <a asp-page="Bioquimico" class="btn med-btn-secondary">
                                Cancelar
                            </a>
                            <button type="submit" class="btn med-btn-primary px-4">
                                Actualizar Registro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
