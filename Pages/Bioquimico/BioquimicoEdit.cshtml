@page
@model ProyectoArqSoft.Pages.BioquimicoEditModel
@{
    ViewData["Title"] = "Editar Bioquímico";
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="med-card shadow-sm">

                <div class="med-card-header text-center">
                    <h2 class="mb-0">Actualizar Bioquímico</h2>
                    <p class="text-muted mt-2 mb-0">
                        Modifica los datos del bioquímico seleccionado
                    </p>
                </div>

                <div class="med-card-body">

                    <form method="post" asp-page-handler="ActualizarBioquimico">

                        <!-- ID oculto -->
                        <input type="hidden" asp-for="IdBioquimico" />

                        <div class="form-floating mb-3">
                            <input asp-for="Nombres"
                                   class="form-control med-input"
                                   placeholder="Nombres"
                                   required />
                            <label asp-for="Nombres"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="ApellidoPaterno"
                                   class="form-control med-input"
                                   placeholder="Apellido Paterno"
                                   required />
                            <label asp-for="ApellidoPaterno"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="ApellidoMaterno"
                                   class="form-control med-input"
                                   placeholder="Apellido Materno"
                                   required />
                            <label asp-for="ApellidoMaterno"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Ci"
                                   class="form-control med-input"
                                   placeholder="CI"
                                   required />
                            <label asp-for="Ci"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="CiExtencion"
                                   class="form-control med-input"
                                   placeholder="Extensión CI"
                                   required />
                            <label asp-for="CiExtencion"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Telefono"
                                   class="form-control med-input"
                                   placeholder="Teléfono"
                                   required />
                            <label asp-for="Telefono"></label>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="/Bioquimico/Bioquimico"
                               class="btn med-btn-secondary">
                                Volver
                            </a>

                            <button type="submit"
                                    class="btn med-btn-primary">
                                Actualizar
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
