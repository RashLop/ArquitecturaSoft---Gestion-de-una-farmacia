@page "{id:int}"
@model ProyectoArqSoft.Pages.BioquimicoEditModel
@{
    ViewData["Title"] = "Editar Bioquímico";
}

<h2>Editar Bioquímico</h2>

<form method="post">
    <input type="hidden" asp-for="IdBioquimico" />

    <div class="form-group mb-2">
        <label>Nombres</label>
        <input asp-for="Nombres" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Apellidos</label>
        <input asp-for="Apellidos" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>CI</label>
        <input asp-for="Ci" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label>Teléfono</label>
        <input asp-for="Telefono" class="form-control" />
    </div>

    

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger">@Model.MensajeError</div>
    }

    <button type="submit" class="btn btn-primary">Actualizar</button>
    <a asp-page="/Bioquimico/Bioquimico" class="btn btn-secondary">Volver</a>
</form>