@page
@model ProyectoArqSoft.Pages.BioquimicoModel
@{ ViewData["Title"] = "Bioquímicos"; }

<h2>Listado de Bioquímicos</h2>

    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="filtro" class="form-control" placeholder="Buscar por nombre o CI..." value="@Model.FiltroActual" />
            <button type="submit" class="btn btn-primary">Buscar</button>
            <a asp-page="/Bioquimico/Bioquimico" class="btn btn-secondary">Limpiar</a>
        </div>
    </form>

<div class="mb-3">
    <a asp-page="/Bioquimico/BioquimicoCreate" class="btn btn-success">Nuevo Bioquímico</a>
</div>

@if (!string.IsNullOrEmpty(Model.Mensaje)) 
{ 
    <div class="alert alert-success">@Model.Mensaje</div>
}
@if (!string.IsNullOrEmpty(Model.MensajeError))
{ 
    <div class="alert alert-danger">@Model.MensajeError</div> 
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombres</th>
            <th>Apellidos</th>
            <th>CI</th>
            <th>Teléfono</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.BioquimicoDataTable.Rows.Count > 0)
        {
            foreach (System.Data.DataRow row in Model.BioquimicoDataTable.Rows)
            {
                <tr>
                    <td>@row["nombres"]</td>
                    <td>@row["apellidos"]</td>
                    <td>@row["ci"]</td>
                    <td>@row["telefono"]</td>
                    <td>
                        <a asp-page="/Bioquimico/BioquimicoEdit" asp-route-id="@row["idBioquimico"]" class="btn btn-warning btn-sm">Editar</a>
                        
                        <form method="post" asp-page-handler="Delete" asp-route-id="@row["idBioquimico"]" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm" 
                                    onclick="return confirm('¿Está seguro de eliminar a este bioquímico?');">
                                Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="5" class="text-center">No se encontraron bioquímicos.</td></tr>
        }
    </tbody>
</table>