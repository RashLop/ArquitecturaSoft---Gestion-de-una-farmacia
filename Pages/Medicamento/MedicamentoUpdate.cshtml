@page
@model ProyectoArqSoft.Pages.MedicamentoUpdateModel
@{
}

<h2>Actualizar Medicamento</h2>

<form method="post">
    <input type="hidden" asp-for="IdMedicamento" />

    <div class="form-group">
        <label>Nombre:</label>
        <input asp-for="Nombre" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Presentación:</label>
        <input asp-for="Presentacion" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Clasificación:</label>
        <input asp-for="Clasificacion" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Concentración:</label>
        <input asp-for="Concentracion" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Precio:</label>
        <input asp-for="Precio" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Stock:</label>
        <input asp-for="Stock" class="form-control" required />
    </div>

        @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger">@Model.MensajeError</div>
    }

    <button type="submit" class="btn btn-primary mt-2">Guardar</button>
    <a asp-page="Medicamento" class="btn btn-secondary mt-2">Volver</a>
</form>