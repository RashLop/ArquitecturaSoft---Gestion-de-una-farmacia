@page "{id:int}"
@model ProyectoArqSoft.Pages.MedicamentoUpdateModel
@{
    ViewData["Title"] = "Editar Medicamento";
}

<h2>Editar Medicamento</h2>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IdMedicamento" />

    <div class="form-group mb-2">
        <label>Nombre del Medicamento</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="row">
        <div class="col-md-6 form-group mb-2">
            <label>Presentación</label>
            <select asp-for="Presentacion" class="form-control">
                <option value="">Seleccione...</option>
                @foreach (var p in Model.Presentaciones)
                {
                    <option value="@p">@p</option>
                }
            </select>
        </div>
        <div class="col-md-6 form-group mb-2">
            <label>Clasificación</label>
            <select asp-for="Clasificacion" class="form-control">
                <option value="">Seleccione...</option>
                @foreach (var c in Model.Clasificaciones)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>
    </div>

    <div class="form-group mb-2">
        <label>Concentración (ej: 500mg, 1g, 10mg/ml)</label>
        <input asp-for="Concentracion" class="form-control" placeholder="Ej: 500mg" />
    </div>

    <div class="row">
        <div class="col-md-6 form-group mb-2">
            <label>Precio (Bs.)</label>
            <input asp-for="Precio" type="number" step="0.01" class="form-control" />
        </div>
        <div class="col-md-6 form-group mb-2">
            <label>Stock</label>
            <input asp-for="Stock" type="number" class="form-control" />
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@Html.Raw(TempData["ErrorMessage"])</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-warning text-white" style="min-width: 120px;">Guardar Cambios</button>
        <a asp-page="Medicamento" class="btn btn-secondary" style="min-width: 100px;">Volver</a>
    </div>
</form>