@page
@model ProyectoArqSoft.Pages.MedicamentoCreateModel
@{
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0">Nuevo Medicamento</h2>
                    <p class="text-muted mt-2 mb-0">Completa los datos para registrar un medicamento</p>
                </div>

                <div class="med-card-body">
                    <form method="post" asp-page-handler="CrearMedicamento">
                        <div class="form-floating mb-3">
                            <input asp-for="Nombre" class="form-control med-input" placeholder="Nombre" required />
                            <label asp-for="Nombre"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Presentacion" class="form-control med-input" placeholder="Presentación" required />
                            <label asp-for="Presentacion"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Clasificacion" class="form-control med-input" placeholder="Clasificación" required />
                            <label asp-for="Clasificacion"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Concentracion" class="form-control med-input" placeholder="Concentración" required />
                            <label asp-for="Concentracion"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Precio" type="number" step="0.01" class="form-control med-input" placeholder="Precio" required />
                            <label asp-for="Precio"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Stock" type="number" class="form-control med-input" placeholder="Stock" required />
                            <label asp-for="Stock"></label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert" role="alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Medicamento" class="btn med-btn-secondary">Volver</a>
                            <button type="submit" class="btn med-btn-primary">Guardar</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>