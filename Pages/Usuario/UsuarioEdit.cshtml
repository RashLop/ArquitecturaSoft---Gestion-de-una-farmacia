@page
@model ProyectoArqSoft.Pages.Usuario.UsuarioEditModel

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm border-0" style="border-radius: 20px;">
                <div class="card-header bg-white text-center py-4 border-0">
                    <h2 class="fw-bold text-success mb-1">Editar Perfil de Usuario</h2>
                    <p class="text-muted small">ID Sistema: #@Model.Input.IdUsuario</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <form method="post" asp-page-handler="ActualizarUsuario">
                        <input type="hidden" asp-for="Input.IdUsuario" />

                        <!-- CAMPO CORREO ELECTRÓNICO -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-success-subtle" placeholder="Email" required />
                            <label class="ms-2">Correo Electrónico</label>
                        </div>

                        <!-- CAMPO NOMBRE DE USUARIO -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.UserName" class="form-control border-success-subtle" placeholder="Username" required />
                            <label class="ms-2">Nombre de Usuario (Username)</label>
                        </div>

                        <div class="row g-2">
                            <!-- CAMPO ROL -->
                            <div class="col-md-6 form-floating mb-3">
                                <select asp-for="Input.Role" class="form-select border-success-subtle">
                                    <option value="Admin">Administrador</option>
                                    <option value="Bioquimico">Bioquímico</option>
                                </select>
                                <label class="ms-2">Rol / Privilegios</label>
                            </div>
                            <!-- CAMPO ESTADO -->
                            <div class="col-md-6 form-floating mb-3">
                                <select asp-for="Input.Activo" class="form-select border-success-subtle">
                                    <option value="1">Habilitado</option>
                                    <option value="0">Deshabilitado (Baja)</option>
                                </select>
                                <label class="ms-2">Estado de Cuenta</label>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger border-0 shadow-sm py-2 text-center mb-3">
                                <i class="bi bi-exclamation-circle-fill me-2"></i> @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <a asp-page="Usuario" class="btn btn-light px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm" style="background-color: #198754;">Actualizar</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>