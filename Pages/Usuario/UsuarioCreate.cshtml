@page
@model ProyectoArqSoft.Pages.Usuarios.UsuarioCreateModel
<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="med-card shadow-lg border-0">
                <div class="med-card-header text-center bg-success text-white py-4">
                    <h2 class="mb-0 fw-bold">Registro de Personal</h2>
                    <small>Complete los datos para habilitar acceso al sistema</small>
                </div>
                <div class="med-card-body p-5">
                    <form method="post" asp-page-handler="CrearUsuario" class="row g-3">
                        <div class="col-md-12 form-floating">
                            <input asp-for="Nombres" class="form-control med-input" placeholder="Nombres" required />
                            <label asp-for="Nombres" class="ms-2"></label>
                        </div>
                        <div class="col-md-6 form-floating">
                            <input asp-for="ApPaterno" class="form-control med-input" placeholder="Paterno" required />
                            <label class="ms-2">Apellido Paterno</label>
                        </div>
                        <div class="col-md-6 form-floating">
                            <input asp-for="ApMaterno" class="form-control med-input" placeholder="Materno" />
                            <label class="ms-2">Apellido Materno</label>
                        </div>
                        <div class="col-md-8 form-floating">
                            <input asp-for="Email" type="email" class="form-control med-input" placeholder="Email" required />
                            <label asp-for="Email" class="ms-2"></label>
                        </div>
                        <div class="col-md-4 form-floating">
                            <select asp-for="Role" class="form-select med-input">
                                <option value="Bioquimico">Bioquímico</option>
                                <option value="Admin">Administrador</option>
                            </select>
                            <label class="ms-2">Rol Asignado</label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert mt-3">@Model.Estado.MensajeError</div>
                        }

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-page="Usuario" class="btn med-btn-secondary px-4">Volver</a>
                            <button type="submit" class="btn med-btn-primary px-5 shadow">Registrar Colaborador</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>