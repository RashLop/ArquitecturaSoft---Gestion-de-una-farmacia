@page
@model ProyectoArqSoft.Pages.ClasificacionUpdateModel
@{
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0">Actualizar Clasificación</h2>
                    <p class="text-muted mt-2 mb-0">Modifica los datos de la clasificación seleccionada</p>
                </div>

                <div class="med-card-body">
                    <form method="post" asp-page-handler="ActualizarClasificacion">
                        <input type="hidden" asp-for="IdClasificacion" />

                        <div class="form-floating mb-3">
                            <input asp-for="Nombre"
                                   class="form-control med-input"
                                   placeholder="Nombre"
                                   required />
                            <label asp-for="Nombre"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <select asp-for="Origen" class="form-select med-input" required>
                                <option value="Natural">Natural</option>
                                <option value="Sintético">Sintético</option>
                                <option value="Semisintético">Semisintético</option>
                            </select>
                            <label asp-for="Origen"></label>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert" role="alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Clasificacion" class="btn med-btn-secondary">Volver</a>
                            <button type="submit" class="btn med-btn-primary">Actualizar</button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>