@page
@model ProyectoArqSoft.Pages.Auth.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Farmacia VitalCare</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <header class="topbar">
        <div class="topbar-container">
            <a asp-page="/Index" class="brand-link">
                <img src="~/images/vitalcare.png" alt="VitalCare" class="brand-logo" />
                <span class="brand-name">VitalCare</span>
            </a>

            <nav class="topbar-nav">
                <a asp-page="/Index">Inicio</a>
                <a asp-page="/Auth/Register">Registro</a>
            </nav>
        </div>
    </header>

    <main class="login-page">
        <section class="login-wrapper">
            <div class="login-left">
                <span class="login-badge">BIENVENIDO</span>

                <h1>Accede a<br />Farmacia VitalCare</h1>

                <p>
                    Ingresa al sistema de gestión farmacéutica para administrar
                    usuarios, inventario, ventas y operaciones de forma segura y eficiente.
                </p>

                <div class="login-note">
                    Utiliza tus credenciales para entrar al sistema. Si aún no tienes una cuenta,
                    puedes registrarte desde la opción correspondiente.
                </div>

                <div class="login-actions">
                    <a asp-page="/Index" class="btn-outline-home">← Volver al inicio</a>
                </div>
            </div>

            <div class="login-right">
                <div class="login-card">
                    <div class="logo-wrap">
                        <img src="~/images/vitalcare.png" alt="VitalCare" class="logo" />
                    </div>

                    <div class="card-header">
                        <h2>Iniciar sesión</h2>
                        <p>Ingresa tus credenciales para acceder al sistema</p>
                    </div>

                    <form method="post" class="login-form">
                        <div class="form-group">
                            <label asp-for="LoginRequest.EmailOUserName">Correo electrónico o nombre de usuario</label>
                            <input type="text"
                                   asp-for="LoginRequest.EmailOUserName"
                                   placeholder="Ej. usuario@correo.com o nombre de usuario"
                                   required />
                        </div>

                        <div class="form-group">
                            <label asp-for="LoginRequest.Password">Contraseña</label>
                            <input type="password"
                                   asp-for="LoginRequest.Password"
                                   placeholder="••••••••"
                                   required />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
                        {
                            <div class="alert alert-error">@Model.MensajeError</div>
                        }

                        <button type="submit" class="btn-login">Ingresar</button>

                        <div class="extra-links">
                            ¿No tienes cuenta?
                            <a asp-page="/Auth/Register">Regístrate</a>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </main>
</body>
</html>